{
  "name": "@gainium/content",
  "version": "1.0.2",
  "description": "Content API service for Gainium documentation and blog",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gainium/content.git"
  },
  "scripts": {
    "dev": "tsx watch -r dotenv/config src/index.ts",
    "build": "tsc",
    "start": "node -r dotenv/config dist/index.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "pull": "git pull origin main",
    "push": "git push origin main",
    "images:webp": "tsx scripts/convert-to-webp.ts",
    "images:webp:dry": "tsx scripts/convert-to-webp.ts --dry-run",
    "images:webp:delete": "tsx scripts/convert-to-webp.ts --delete",
    "lint": "tsc --noEmit && eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky"
  },
  "keywords": [
    "content",
    "api",
    "documentation",
    "blog"
  ],
  "author": "Gainium",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.0",
    "node-cron": "^3.0.3",
    "simple-git": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^9.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.19",
    "@types/node-cron": "^3.0.11",
    "@types/sharp": "^0.31.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-unused-imports": "^4.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.11",
    "prettier": "^3.2.5",
    "sharp": "^0.34.5",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
